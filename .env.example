# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or any file with real secrets
# ===========================================

# ===========================================
# REQUIRED
# ===========================================

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ===========================================
# OPTIONAL - Email (Contact Form)
# ===========================================

# Resend API Key - Get from https://resend.com
# Required for contact form to work in production
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email where contact form submissions are sent
CONTACT_EMAIL=your-email@example.com

# Verified sender email in Resend (must be verified domain or use default)
FROM_EMAIL=contact@your-verified-domain.com

# ===========================================
# OPTIONAL - Analytics
# ===========================================

# Google Analytics Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# OPTIONAL - Development
# ===========================================

# Node environment (automatically set by Next.js)
# NODE_ENV=development
